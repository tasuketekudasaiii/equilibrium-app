// Equilibrium — Firestore Security Rules
//
// Apply these in the Firebase Console:
//   Firebase Console → Firestore Database → Rules → paste → Publish
//
// What these rules enforce:
//   • A signed-in user can ONLY read/write their own document.
//   • No user can access another user's health data, even if they know the UID.
//   • Unauthenticated requests are rejected entirely.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All health data lives at: /users/{userId}/data/health
    match /users/{userId}/data/health {
      allow read, write: if
        request.auth != null &&          // must be signed in
        request.auth.uid == userId;      // can only access own document
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
